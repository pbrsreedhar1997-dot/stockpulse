# ─────────────────────────────────────────────────────────────
# StockPulse Configuration  —  copy this file to stockpulse.env
# ─────────────────────────────────────────────────────────────

# ── AI (required) ─────────────────────────────────────────────
# Free Groq key → https://console.groq.com → API Keys → Create Key
GROQ_API_KEY=gsk_paste_your_key_here

# Paid Anthropic fallback (optional — only if no Groq key)
# ANTHROPIC_API_KEY=sk-ant-paste_your_key_here

# ── Supabase Database (required for production) ───────────────
# 1. Go to https://supabase.com → New project
# 2. Settings → Database → Connection string → Session pooler URI
# 3. Paste the full URI below (it starts with postgresql://)
#
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:5432/postgres

# ── Optional extras ───────────────────────────────────────────
# Finnhub API key (extra news source) → https://finnhub.io
# FINNHUB_API_KEY=your_finnhub_key_here
