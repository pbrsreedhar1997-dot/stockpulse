# StockPulse AI Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to stockpulse.env and fill in your keys.
#
# FREE option (recommended) — Groq API key:
#   1. Go to https://console.groq.com
#   2. Sign up (no credit card needed)
#   3. API Keys → Create Key → copy gsk_...
#
GROQ_API_KEY=gsk_paste_your_key_here
#
# Paid option — Anthropic Claude:
# (Only needed if you don't use Groq)
# ANTHROPIC_API_KEY=sk-ant-paste_your_key_here
#
# Optional — Finnhub API key (adds extra news sources):
#   1. Go to https://finnhub.io
#   2. Sign up free → Dashboard → API Key
# FINNHUB_API_KEY=your_finnhub_key_here
#
# Optional — PostgreSQL + pgvector (faster AI similarity search):
#   Homebrew PostgreSQL 17 on port 5433:
# DATABASE_URL=postgresql://localhost:5433/stockpulse
